# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# 2 space indent for all JS files
[*.{js,json,css,html,md}]
indent_style = space
indent_size = 2

# YAML indentation
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown specific
[*.md]
trim_trailing_whitespace = false
max_line_length = 100

# JSON files
[*.json]
indent_style = space
indent_size = 2

# HTML
[*.html]
indent_style = space
indent_size = 2
